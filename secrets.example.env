# ============================================================
# Poly CopyBot — Secrets (KEEP PRIVATE, never commit!)
# Copy this to secrets.env and fill in your values
# ============================================================

# --- Polymarket CLOB API (REQUIRED for live trading) ---
# Export your private key from your Polymarket wallet
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=

# --- Builder API (REQUIRED for auto-redeem of won positions) ---
# Get from polymarket.com/settings -> Builder -> Create New
BUILDER_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# --- Dashboard ---
DASHBOARD_SECRET=changeme   # Required for follow/unfollow/reset/close API endpoints
